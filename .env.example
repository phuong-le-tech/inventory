# ================================================
# Copy this file to .env.dev and fill in the values
# Usage: docker compose -f docker-compose.dev.yml up --build
# ================================================

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventory
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Spring Boot profile (dev | prod)
# To enable Google OAuth: SPRING_PROFILES_ACTIVE=dev,oauth
SPRING_PROFILES_ACTIVE=dev

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# JWT signing secret (min 32 chars — generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_256_BIT_STRING
JWT_EXPIRATION_MS=86400000

# Cookie configuration
COOKIE_SECURE=false
FRONTEND_URL=http://localhost:5173

# Google OAuth2 (optional — only needed if oauth profile is active)
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
